    },
    {
      "type": "paragraph",
      "html": "<a href=\"#\" class=\"hint-check\"><i class=\"fa fa-check\"></i></a><span class=\"amount\">1-2 </span> <span class=\"name\">Bananas</span>"
    },
    {
      "type": "paragraph",
