# Copy to .env.local for local development
# The Apps Script web app URL from Deploy → Web app
NEXT_PUBLIC_BOOKING_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Do NOT add ADMIN_PASSWORD here or as NEXT_PUBLIC_* — it must only live in
# Apps Script Script Properties (and optionally as a GitHub Actions secret for ops).
